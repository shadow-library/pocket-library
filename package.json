{
  "name": "pocket-library",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/lora": "^0.4.2",
    "@expo-google-fonts/roboto": "^0.4.3",
    "@expo/ui": "~57.0.3",
    "@expo/vector-icons": "^15.0.2",
    "expo": "~57.0.2",
    "expo-brightness": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-dev-client": "^57.0.5",
    "expo-device": "~57.0.0",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-router": "~57.0.3",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "fflate": "^0.8.3",
    "markdown-it": "^14.3.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/react": "~19.2.2",
    "eas-cli": "^20.5.1",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~57.0.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "make:novel": "node scripts/make-novel.mjs",
    "make:sample": "node scripts/make-novel.mjs sample/the-rain-road",
    "build:development": "eas build --profile development --platform android",
    "build:preview": "eas build --profile preview --platform android",
    "build:production": "eas build --profile production --platform android",
    "build:production:install": "eas build --profile production-apk --platform android --local --non-interactive --output build/pocket-library-production.apk && adb install -r build/pocket-library-production.apk"
  },
  "private": true
